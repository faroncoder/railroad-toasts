  },
  "keywords": [
    "toast",
    "notifications",
    "alerts",
    "confirm",
    "dialog",
    "htmx",
    "ui",
    "railroad",
    "vanilla-js",
    "zero-dependencies"
  ],
  "author": "Faron Coder",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/faroncoder/railroad-toasts.git"
  },
  "bugs": {
    "url": "https://github.com/faroncoder/railroad-toasts/issues"
  },
  "homepage": "https://github.com/faroncoder/railroad-toasts#readme",
  "devDependencies": {
    "terser": "^5.16.0"
  },
  "files": [
    "dist/",
    "src/",
    "examples/",
    "README.md",
    "LICENSE"
  ]
}
