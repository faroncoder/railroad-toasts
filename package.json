{
  "name": "railroad-toasts",
  "version": "1.0.1",
  "description": "Toast notifications and confirm dialogs for web applications. Built on Railroad Runtime philosophy.",
  "main": "dist/toasts.js",
  "unpkg": "dist/toasts.min.js",
  "jsdelivr": "dist/toasts.min.js",
  "scripts": {
    "build": "mkdir -p dist && cp src/toasts.js dist/ && npx terser src/toasts.js -c -m -o dist/toasts.min.js",
